---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-40 backdrop-blur-md bg-background/80 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <span class="text-xl font-bold text-foreground tracking-tight">scurry</span>
        <span class="text-[11px] font-mono text-primary bg-primary/10 px-2 py-0.5 rounded-full">beta</span>
      </a>
      <div class="flex items-center gap-4">
        <a href="https://blog.scurry.space" class="text-sm text-muted-foreground hover:text-foreground">Blog</a>
        <a href="https://app.scurry.space" class="text-sm font-medium text-primary-foreground bg-primary hover:bg-primary/90 px-4 py-2 rounded-lg">
          Open App &rarr;
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center pt-14">
    <div class="absolute top-32 left-[10%] w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-[15%] w-80 h-80 bg-accent/10 rounded-full blur-3xl"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
      <div class="max-w-2xl">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 bg-secondary border border-border rounded-full px-3 py-1 mb-6" style="animation: fade-in-up 0.6s ease-out forwards;">
          <span class="inline-block w-1.5 h-1.5 bg-success rounded-full animate-pulse"></span>
          <span class="text-xs text-muted-foreground font-mono">for people who learn by doing</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.1] tracking-tight mb-5" style="animation: fade-in-up 0.8s ease-out 0.1s both;">
          Stop hoarding tabs.<br/>
          <span class="text-primary">Start actually learning.</span>
        </h1>

        <!-- Subhead -->
        <p class="text-base sm:text-lg text-muted-foreground max-w-lg mb-4 leading-relaxed" style="animation: fade-in-up 0.8s ease-out 0.25s both;">
          You've got 47 bookmarked tutorials, 3 half-finished courses, and a YouTube "Watch Later" that's basically a graveyard. Sound familiar?
        </p>
        <p class="text-base sm:text-lg text-muted-foreground max-w-lg mb-8 leading-relaxed" style="animation: fade-in-up 0.8s ease-out 0.35s both;">
          Scurry turns that chaos into a <strong class="text-foreground font-semibold">real learning roadmap</strong> — with AI that actually knows where you're going.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-3" style="animation: fade-in-up 0.8s ease-out 0.45s both;">
          <a href="https://app.scurry.space" class="group inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-6 py-3 rounded-xl text-base hover:bg-primary/90 shadow-sm hover:shadow-md">
            Start Learning
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m13 7 5 5m0 0-5 5m5-5H6"/></svg>
          </a>
          <a href="#how-it-works" class="inline-flex items-center gap-2 text-muted-foreground font-medium px-4 py-3 rounded-xl hover:bg-secondary">
            See how it works
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/></svg>
          </a>
        </div>
      </div>

      <!-- One-line squirrel — draws itself on load -->
      <div class="hidden lg:block absolute right-8 top-1/2 -translate-y-1/2" style="animation: float 6s ease-in-out 1.5s infinite; animation-fill-mode: both;">
        <div class="w-72 h-72 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
            <path class="line-draw" d="
              M 200 60
              C 180 55, 160 65, 155 85
              C 150 105, 165 120, 175 115
              C 180 112, 178 105, 175 100
              C 172 95, 168 98, 170 105
              M 185 115
              C 190 125, 185 140, 180 155
              C 175 170, 170 185, 172 200
              C 174 215, 180 225, 190 230
              C 200 235, 210 230, 215 225
              C 225 215, 225 200, 220 190
              C 215 180, 205 178, 200 182
              C 195 186, 195 195, 200 200
              M 190 230
              C 185 240, 178 248, 175 260
              C 172 275, 178 285, 188 285
              C 195 285, 200 280, 200 275
              M 210 225
              C 215 240, 218 250, 222 260
              C 226 275, 230 285, 225 290
              C 220 295, 212 290, 215 282
              M 220 190
              C 235 185, 250 190, 260 205
              C 275 225, 280 255, 270 280
              C 260 305, 240 320, 225 330
              C 210 340, 205 345, 210 350
              C 220 360, 240 355, 255 340
              C 275 320, 290 290, 295 260
              C 300 230, 295 200, 280 180
              C 265 160, 245 150, 230 148
              C 220 146, 215 150, 218 158
              M 165 88
              C 160 82, 162 75, 168 73
              C 174 71, 178 76, 176 82
              M 170 95
              C 166 92, 167 88, 171 88
              C 174 88, 174 92, 171 93
            "/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Ticker -->
  <section class="border-y border-border bg-surface-subtle py-4 overflow-hidden">
    <div class="flex items-center gap-10 whitespace-nowrap" style="animation: scroll 30s linear infinite;">
      {["Built with AI, refined by humans", "Community-driven roadmaps", "Learn anything, your way", "Track real progress", "AI tutor that gets you", "No more tutorial hell", "Built with AI, refined by humans", "Community-driven roadmaps", "Learn anything, your way", "Track real progress", "AI tutor that gets you", "No more tutorial hell"].map((text) => (
        <span class="text-xs font-mono text-muted-foreground flex items-center gap-2.5">
          <span class="w-1 h-1 bg-primary/30 rounded-full shrink-0"></span>
          {text}
        </span>
      ))}
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-20 sm:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="max-w-xl mx-auto text-center mb-12">
        <p class="font-mono text-xs text-primary mb-3 tracking-wide uppercase">The Problem</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Tutorial Hell is real. We've all been there.</h2>
        <p class="text-muted-foreground text-base">You start with motivation. Then it fragments into 20 browser tabs, 5 bookmarked repos, and a vague sense of guilt.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="card-hover bg-card border border-border rounded-xl p-6">
          <div class="text-3xl mb-3">📑</div>
          <h3 class="font-semibold text-base mb-1.5">The Tab Hoarder</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">"I'll read this later" you say, opening tab #47. You won't. You'll feel bad about it though.</p>
          <div class="mt-3 font-mono text-[11px] text-muted-foreground/60 bg-surface-subtle rounded-lg p-2.5">
            Chrome: 47 tabs<br/>
            Memory: 12.4 GB<br/>
            Knowledge gained: 0
          </div>
        </div>

        <div class="card-hover bg-card border border-border rounded-xl p-6">
          <div class="text-3xl mb-3">🎬</div>
          <h3 class="font-semibold text-base mb-1.5">The Course Collector</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Udemy sale? Buy 8 courses. Finish 0. Your "Watch Later" is now an archive of abandoned ambitions.</p>
          <div class="mt-3 font-mono text-[11px] text-muted-foreground/60 bg-surface-subtle rounded-lg p-2.5">
            Courses bought: 23<br/>
            Courses completed: 1.5<br/>
            Spent: $347
          </div>
        </div>

        <div class="card-hover bg-card border border-border rounded-xl p-6">
          <div class="text-3xl mb-3">🔄</div>
          <h3 class="font-semibold text-base mb-1.5">The Eternal Beginner</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">You've "learned" React 4 times. Still can't build a todo app without a tutorial open.</p>
          <div class="mt-3 font-mono text-[11px] text-muted-foreground/60 bg-surface-subtle rounded-lg p-2.5">
            Times learned React: 4<br/>
            React apps shipped: 0<br/>
            Imposter syndrome: MAX
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it Works -->
  <section id="how-it-works" class="py-20 sm:py-24 bg-dark-bg text-dark-fg relative overflow-hidden">
    <div class="absolute top-0 right-0 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 relative">
      <div class="max-w-xl mx-auto text-center mb-16">
        <p class="font-mono text-xs text-accent mb-3 tracking-wide uppercase">How It Works</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Three steps. No BS.</h2>
        <p class="text-dark-muted text-base">From "I want to learn X" to actually learning X.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="relative">
          <div class="text-7xl font-bold text-dark-fg/[0.04] absolute -top-6 -left-1">1</div>
          <div class="relative bg-dark-card border border-dark-border rounded-xl p-6">
            <div class="w-10 h-10 bg-destructive rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Pick your quest</h3>
            <p class="text-dark-muted text-sm leading-relaxed">Tell Scurry what you want to learn. Browse community roadmaps or create your own from scratch.</p>
          </div>
        </div>

        <div class="relative md:mt-8">
          <div class="text-7xl font-bold text-dark-fg/[0.04] absolute -top-6 -left-1">2</div>
          <div class="relative bg-dark-card border border-dark-border rounded-xl p-6">
            <div class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-accent-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">AI builds your map</h3>
            <p class="text-dark-muted text-sm leading-relaxed">Scurry's AI creates a structured learning path — the right resources, in the right order, at the right level.</p>
          </div>
        </div>

        <div class="relative md:mt-16">
          <div class="text-7xl font-bold text-dark-fg/[0.04] absolute -top-6 -left-1">3</div>
          <div class="relative bg-dark-card border border-dark-border rounded-xl p-6">
            <div class="w-10 h-10 bg-success rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Learn. For real.</h3>
            <p class="text-dark-muted text-sm leading-relaxed">Work through your roadmap with an AI tutor. Track progress. Build projects. Ship things.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 sm:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="max-w-xl mx-auto text-center mb-12">
        <p class="font-mono text-xs text-primary mb-3 tracking-wide uppercase">Features</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Everything you need. Nothing you don't.</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { icon: "🗺️", title: "AI Roadmaps", desc: "Tell it what you want to learn. Get a structured path with the best resources, ordered correctly." },
          { icon: "🤖", title: "AI Tutor", desc: "Stuck on a concept? Ask your AI tutor. It knows your roadmap, your level, and where you left off." },
          { icon: "🍴", title: "Fork & Remix", desc: "Found a great roadmap? Fork it, customize it, make it yours. Like GitHub but for learning." },
          { icon: "📊", title: "Real Progress", desc: "Not fake gamification. Actual tracking of what you've learned, built, and shipped." },
          { icon: "🧠", title: "Use Your Own AI", desc: "One click to export your roadmap to ChatGPT, Claude, or Gemini. Your learning, your tools." },
          { icon: "👥", title: "Community", desc: "Browse roadmaps built by other learners. Share yours. Learn from people who've been there." },
        ].map(({ icon, title, desc }) => (
          <div class="card-hover bg-card border border-border rounded-xl p-5">
            <div class="text-2xl mb-2">{icon}</div>
            <h3 class="font-semibold text-sm mb-1">{title}</h3>
            <p class="text-xs text-muted-foreground leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="py-20 sm:py-24 bg-surface-subtle">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="max-w-xl mx-auto text-center mb-12">
        <p class="font-mono text-xs text-primary mb-3 tracking-wide uppercase">Coming Soon</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Your learning, everywhere.</h2>
        <p class="text-muted-foreground text-base">Scurry plays nice with the tools you already use.</p>
      </div>

      <div class="flex flex-wrap justify-center gap-3">
        {[
          { name: "Obsidian", desc: "Export to vault" },
          { name: "Notion", desc: "Sync pages" },
          { name: "ChatGPT", desc: "One-click prompt" },
          { name: "Claude", desc: "Deep dive" },
          { name: "Gemini", desc: "Study sessions" },
          { name: "NotebookLM", desc: "Push resources" },
        ].map(({ name, desc }) => (
          <div class="bg-card border border-border rounded-lg px-4 py-3 text-center hover:border-primary/30 hover:shadow-sm card-hover">
            <div class="font-semibold text-xs">{name}</div>
            <div class="text-[11px] text-muted-foreground mt-0.5">{desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/3 via-transparent to-accent/5"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 relative">
      <div class="max-w-lg mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
          Ready to stop collecting<br/>and start <span class="text-primary">learning</span>?
        </h2>
        <p class="text-muted-foreground text-base mb-8">
          Your future self will thank you. Or at least have fewer tabs open.
        </p>
        <a href="https://app.scurry.space" class="group inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-8 py-3.5 rounded-xl text-base hover:bg-primary/90 shadow-sm hover:shadow-md">
          Start Learning — It's Free
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m13 7 5 5m0 0-5 5m5-5H6"/></svg>
        </a>
        <p class="text-xs text-muted-foreground mt-3">No credit card. No commitment. Just learning.</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-border py-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <span class="text-lg font-bold text-foreground">scurry</span>
          <span class="text-xs text-muted-foreground">Learn, Build, Share.</span>
        </div>
        <div class="flex items-center gap-4 text-xs text-muted-foreground">
          <a href="https://app.scurry.space" class="hover:text-foreground">App</a>
          <a href="https://blog.scurry.space" class="hover:text-foreground">Blog</a>
          <a href="https://app.scurry.space/privacy" class="hover:text-foreground">Privacy</a>
          <a href="https://app.scurry.space/terms" class="hover:text-foreground">Terms</a>
        </div>
      </div>
      <div class="mt-6 pt-4 border-t border-border text-center">
        <p class="text-[11px] text-muted-foreground/60">Built by a squirrel who got tired of hoarding tabs. &copy; {new Date().getFullYear()} Scurry.</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Line-draw animation for one-line art SVGs */
  .line-draw {
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
    animation: draw 3s ease-in-out 0.5s forwards;
  }

  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  /* Ticker scroll */
  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>

<script>
  // Calculate actual path lengths for precise line-draw animation
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.line-draw').forEach((path) => {
      if (path instanceof SVGPathElement) {
        const length = path.getTotalLength();
        path.style.strokeDasharray = String(length);
        path.style.strokeDashoffset = String(length);
      }
    });
  });
</script>
