---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-40 backdrop-blur-md bg-background/85 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/illustrations/squirrel-logo.svg" alt="" class="w-7 h-7" />
        <span class="text-xl font-bold text-foreground tracking-tight">scurry</span>
      </a>
      <div class="flex items-center gap-2 sm:gap-4">
        <a href="https://blog.scurry.space" class="text-sm text-muted-foreground hover:text-foreground px-2 py-1">Blog</a>
        <a href="https://app.scurry.space" class="text-sm font-semibold text-primary-foreground bg-primary hover:bg-primary/90 px-4 py-2 rounded-xl">
          Try Scurry Free &rarr;
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center pt-14">
    <div class="absolute top-32 left-[10%] w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-[15%] w-80 h-80 bg-accent/10 rounded-full blur-3xl"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8 items-center">
        <div>
          <!-- Eyebrow -->
          <div class="inline-flex items-center gap-2 bg-secondary border border-border rounded-full px-3 py-1 mb-6" style="animation: fade-in-up 0.6s ease-out forwards;">
            <span class="inline-block w-1.5 h-1.5 bg-success rounded-full animate-pulse"></span>
            <span class="text-xs text-muted-foreground font-mono">for people who learn by doing</span>
          </div>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold leading-[1.05] tracking-tight mb-5" style="animation: fade-in-up 0.8s ease-out 0.1s both;">
            Stop hoarding tabs.<br/>
            <span class="text-accent">Start actually learning.</span>
          </h1>

          <!-- Subhead -->
          <p class="text-base sm:text-lg text-muted-foreground max-w-lg mb-4 leading-relaxed" style="animation: fade-in-up 0.8s ease-out 0.25s both;">
            You've got 47 bookmarked tutorials, 3 half-finished courses, and a YouTube "Watch Later" that's basically a graveyard.
          </p>
          <p class="text-base sm:text-lg text-muted-foreground max-w-lg mb-8 leading-relaxed" style="animation: fade-in-up 0.8s ease-out 0.35s both;">
            Scurry turns that chaos into a <strong class="text-accent font-semibold">real learning roadmap</strong> — with AI that actually knows where you're going.
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap items-center gap-3" style="animation: fade-in-up 0.8s ease-out 0.45s both;">
            <a href="https://app.scurry.space" class="group inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-6 py-3 rounded-xl text-base hover:bg-primary/90 shadow-sm hover:shadow-md hover:scale-[1.02]">
              Try Scurry Free
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m13 7 5 5m0 0-5 5m5-5H6"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 text-muted-foreground font-medium px-4 py-3 rounded-xl hover:bg-secondary">
              See how it works
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/></svg>
            </a>
          </div>
        </div>

        <!-- Squirrel mascot — grid-anchored, visible on mobile too -->
        <div class="flex justify-center lg:justify-end" style="animation: fade-in-up 1s ease-out 0.5s both;">
          <div class="w-40 h-40 lg:w-72 lg:h-72" style="animation: float 8s ease-in-out 1.5s infinite;">
            <img src="/illustrations/squirrel-logo.svg" alt="Scurry squirrel mascot" class="w-full h-full drop-shadow-lg" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Bar -->
  <section class="border-y border-border bg-surface-subtle py-5" data-reveal>
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10 text-center">
        <div class="flex items-center gap-2">
          <span class="text-accent text-lg">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="text-sm text-muted-foreground">Loved by early learners</span>
        </div>
        <span class="hidden sm:block w-px h-5 bg-border"></span>
        <div class="text-sm text-muted-foreground">
          <strong class="text-foreground font-semibold">500+</strong> roadmaps created
        </div>
      </div>
    </div>
  </section>

  <!-- How it Works — moved up per PM recommendation -->
  <section id="how-it-works" class="noise-texture section-dark py-24 sm:py-32 bg-surface-dark text-[hsl(220_14%_94%)] relative overflow-hidden">
    <div class="absolute top-0 right-0 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="max-w-xl mx-auto text-center mb-16" data-reveal>
        <p class="font-mono text-xs text-accent mb-3 tracking-wide uppercase">How It Works</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4">Three steps. No BS.</h2>
        <p class="text-surface-dark-muted text-base">From "I want to learn X" to actually learning X.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="relative" data-reveal>
          <div class="text-7xl font-bold text-white/[0.04] absolute -top-6 -left-1">1</div>
          <div class="dark-card relative bg-surface-dark-card border border-surface-dark-border rounded-xl p-6">
            <div class="w-10 h-10 bg-destructive rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Pick your quest</h3>
            <p class="text-surface-dark-muted text-sm leading-relaxed">Tell Scurry what you want to learn. Browse community roadmaps or create your own from scratch.</p>
          </div>
        </div>

        <div class="relative md:mt-12" data-reveal>
          <div class="text-7xl font-bold text-white/[0.04] absolute -top-6 -left-1">2</div>
          <div class="dark-card relative bg-surface-dark-card border border-surface-dark-border rounded-xl p-6">
            <div class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-accent-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">AI builds your map</h3>
            <p class="text-surface-dark-muted text-sm leading-relaxed">Scurry's AI creates a structured learning path — the right resources, in the right order, at the right level.</p>
          </div>
        </div>

        <div class="relative md:mt-24" data-reveal>
          <div class="text-7xl font-bold text-white/[0.04] absolute -top-6 -left-1">3</div>
          <div class="dark-card relative bg-surface-dark-card border border-surface-dark-border rounded-xl p-6">
            <div class="w-10 h-10 bg-success rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Learn. For real.</h3>
            <p class="text-surface-dark-muted text-sm leading-relaxed">Work through your roadmap with an AI tutor. Track progress. Build projects. Ship things.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem — compressed, moved after How It Works -->
  <section class="py-24 sm:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="max-w-xl mx-auto text-center mb-12" data-reveal>
        <p class="font-mono text-xs text-primary mb-3 tracking-wide uppercase">Sound Familiar?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4">Tutorial Hell is real.</h2>
        <p class="text-muted-foreground text-base">You start with motivation. Then it fragments into 20 browser tabs, 5 bookmarked repos, and a vague sense of guilt.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="card-hover bg-card border border-border rounded-xl p-6" data-reveal>
          <div class="text-3xl mb-3">&#x1F4D1;</div>
          <h3 class="font-semibold text-base mb-1.5">The Tab Hoarder</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">"I'll read this later" you say, opening tab #47. You won't. You'll feel bad about it though.</p>
          <div class="mt-3 bg-surface-subtle rounded-lg p-3">
            <div class="terminal-dots">
              <span class="bg-red-400/60"></span>
              <span class="bg-yellow-400/60"></span>
              <span class="bg-green-400/60"></span>
            </div>
            <div class="font-mono text-xs text-muted-foreground/60 leading-loose">
              Chrome: 47 tabs<br/>
              Memory: 12.4 GB<br/>
              Knowledge gained: 0
