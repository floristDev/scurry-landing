          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <section class="py-12 bg-surface-subtle border-y border-border" data-reveal>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-lg font-semibold mb-3">Ready to break the cycle?</p>
      <a href="https://app.scurry.space" class="group inline-flex items-center gap-2 bg-primary text-primary-foreground font-semibold px-6 py-3 rounded-xl text-base hover:bg-primary/90 shadow-sm hover:shadow-md hover:scale-[1.02]">
        Try Scurry Free
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m13 7 5 5m0 0-5 5m5-5H6"/></svg>
      </a>
      <p class="text-xs text-muted-foreground mt-2">No credit card required.</p>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 sm:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="max-w-xl mx-auto text-center mb-12" data-reveal>
        <p class="font-mono text-xs text-primary mb-3 tracking-wide uppercase">Features</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4">Everything you need. Nothing you don't.</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: "\u{1F5FA}\u{FE0F}", title: "AI Roadmaps", desc: "Tell it what you want to learn. Get a structured path with the best resources, ordered correctly." },
          { icon: "\u{1F916}", title: "AI Tutor", desc: "Stuck on a concept? Ask your AI tutor. It knows your roadmap, your level, and where you left off." },
          { icon: "\u{1F374}", title: "Fork & Remix", desc: "Found a great roadmap? Fork it, customize it, make it yours. Like GitHub but for learning." },
          { icon: "\u{1F4CA}", title: "Real Progress", desc: "Not fake gamification. Actual tracking of what you've learned, built, and shipped." },
          { icon: "\u{1F9E0}", title: "Export Anywhere", desc: "One click to export your roadmap to ChatGPT, Claude, or Gemini. Your learning, your tools." },
          { icon: "\u{1F465}", title: "Community", desc: "Browse roadmaps built by other learners. Share yours. Learn from people who've been there." },
        ].map(({ icon, title, desc }) => (
          <div class="card-hover bg-card border border-border rounded-xl p-6" data-reveal>
            <div class="text-2xl mb-3">{icon}</div>
